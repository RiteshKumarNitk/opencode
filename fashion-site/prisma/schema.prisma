generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
  RETURN_REQUESTED
  RETURNED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  RAZORPAY
  COD
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          Role     @default(CUSTOMER)
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  cart          Cart?
  orders        Order[]
  addresses     Address[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  resetTokens   PasswordResetToken[]
  socialAccounts SocialAccount[]
  auditLogs     AuditLog[]
  adminUsers    AdminUser[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────
// CATEGORY (e.g., Women > Dresses, Sarees, Kurtas)
// ─────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  products    Product[]

  @@index([parentId])
  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String   @db.Text
  shortDesc     String?
  images        String[]
  price         Decimal  @db.Decimal(10, 2)
  comparePrice  Decimal? @db.Decimal(10, 2)
  sku           String?
  brand         String?
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  sortOrder     Int      @default(0)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id])

  variants      ProductVariant[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  flashSaleProducts FlashSaleProduct[]
  bundleProducts    BundleProduct[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([price])
  @@map("products")
}

// ─────────────────────────────────────────────
// PRODUCT VARIANT (Size, Color combinations)
// ─────────────────────────────────────────────

model ProductVariant {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  price         Decimal  @db.Decimal(10, 2)
  comparePrice  Decimal? @db.Decimal(10, 2)
  stock         Int      @default(0)
  attributes    Json     // { "size": "M", "color": "Red" }
  images        String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  productId     String
  product       Product     @relation(fields: [productId], references: [id])

  orderItems    OrderItem[]
  cartItems     CartItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model Cart {
  id            String     @id @default(cuid())
  sessionId     String?    @unique
  totalAmount   Decimal    @default(0) @db.Decimal(10, 2)
  itemCount     Int        @default(0)
  expiresAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userId        String?    @unique
  user          User?      @relation(fields: [userId], references: [id])

  items         CartItem[]
  couponId      String?
  coupon        Coupon?    @relation(fields: [couponId], references: [id])
  discount      Decimal    @default(0) @db.Decimal(10, 2)

  @@index([sessionId])
  @@map("carts")
}

// ─────────────────────────────────────────────
// CART ITEM
// ─────────────────────────────────────────────

model CartItem {
  id            String   @id @default(cuid())
  quantity      Int      @default(1)
  unitPrice     Decimal  @db.Decimal(10, 2)
  totalPrice    Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cartId        String
  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId     String
  product       Product  @relation(fields: [productId], references: [id])

  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id              String       @id @default(cuid())
  orderNumber     String       @unique
  status          OrderStatus  @default(PENDING)
  subtotal        Decimal      @db.Decimal(10, 2)
  tax             Decimal      @default(0) @db.Decimal(10, 2)
  shippingCost    Decimal      @default(0) @db.Decimal(10, 2)
  discount        Decimal      @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal      @db.Decimal(10, 2)
  notes           String?      @db.Text
  couponCode      String?
  metadata        Json?
  guestEmail      String?      // For guest checkout
  guestPhone      String?      // For guest checkout
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  confirmedAt     DateTime?
  processingAt    DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  deletedAt       DateTime?

  userId          String?
  user            User?        @relation(fields: [userId], references: [id])

  items           OrderItem[]
  payment         Payment?
  addressId       String
  address         Address      @relation(fields: [addressId], references: [id])

  shipment        Shipment?
  returnRequests ReturnRequest[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([guestEmail])
  @@map("orders")
}

// ─────────────────────────────────────────────
// ORDER ITEM
// ─────────────────────────────────────────────

model OrderItem {
  id            String   @id @default(cuid())
  productName   String
  sku           String?
  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2)
  totalPrice    Decimal  @db.Decimal(10, 2)
  attributes    Json?
  createdAt     DateTime @default(now())

  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])

  productId     String
  product       Product  @relation(fields: [productId], references: [id])

  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  gatewayOrderId  String?
  gatewayPaymentId String?
  signature       String?
  method          PaymentMethod @default(RAZORPAY)
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("INR")
  failureReason   String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])

  @@index([gatewayPaymentId])
  @@map("payments")
}

// ─────────────────────────────────────────────
// ADDRESS
// ─────────────────────────────────────────────

model Address {
  id            String   @id @default(cuid())
  label         String   @default("Home")
  fullName      String
  phone         String
  line1         String
  line2         String?
  city          String
  state         String
  postalCode    String
  country       String   @default("IN")
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  orders        Order[]

  @@index([userId])
  @@map("addresses")
}

// ─────────────────────────────────────────────
// COUPON
// ─────────────────────────────────────────────

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountType    String    @default("PERCENTAGE")
  discountValue   Decimal   @db.Decimal(10, 2)
  minOrderAmount  Decimal?  @db.Decimal(10, 2)
  maxDiscount     Decimal?  @db.Decimal(10, 2)
  usageLimit      Int?
  usedCount       Int       @default(0)
  isActive        Boolean   @default(true)
  startsAt        DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  carts           Cart[]

  @@index([code])
  @@map("coupons")
}

// ─────────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────────

model WishlistItem {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────
// PRODUCT REVIEW
// ─────────────────────────────────────────────

model Review {
  id            String   @id @default(cuid())
  rating        Int
  title         String?
  comment       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// PASSWORD RESET TOKEN
// ─────────────────────────────────────────────

model PasswordResetToken {
  id            String   @id @default(cuid())
  token         String   @unique
  expiresAt     DateTime
  used          Boolean  @default(false)
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// SOCIAL LOGIN
// ─────────────────────────────────────────────

model SocialAccount {
  id            String   @id @default(cuid())
  provider      String   // "google", "facebook"
  providerId    String
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("social_accounts")
}

// ─────────────────────────────────────────────
// NEWSLETTER SUBSCRIPTION
// ─────────────────────────────────────────────

model NewsletterSubscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  isActive      Boolean  @default(true)
  subscribedAt  DateTime @default(now())
  unsubscribedAt DateTime?

  @@index([email])
  @@map("newsletter_subscribers")
}

// ─────────────────────────────────────────────
// STOCK ALERT (Notify when available)
// ─────────────────────────────────────────────

model StockAlert {
  id            String   @id @default(cuid())
  email         String
  isNotified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  notifiedAt    DateTime?

  productId     String
  variantId     String?

  @@index([productId, variantId])
  @@index([email])
  @@map("stock_alerts")
}

// ─────────────────────────────────────────────
// PRODUCT COMPARISON
// ─────────────────────────────────────────────

model ComparisonList {
  id            String   @id @default(cuid())
  sessionId     String?
  userId        String?
  productIds    String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sessionId])
  @@index([userId])
  @@map("comparison_lists")
}

// ─────────────────────────────────────────────
// SHIPPING TRACKING
// ─────────────────────────────────────────────

model Shipment {
  id              String   @id @default(cuid())
  trackingNumber  String?
  carrier          String?  // "shiprocket", "delhivery", etc.
  labelUrl        String?
  currentStatus   String?
  estimatedDelivery DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])

  trackingEvents  ShipmentEvent[]

  @@index([trackingNumber])
  @@index([carrier])
  @@map("shipments")
}

model ShipmentEvent {
  id            String   @id @default(cuid())
  status        String
  location      String?
  description   String?
  timestamp     DateTime

  shipmentId    String
  shipment      Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
  @@map("shipment_events")
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

model AnalyticsEvent {
  id            String   @id @default(cuid())
  eventType     String   // "page_view", "product_view", "add_to_cart", "purchase"
  sessionId     String?
  userId        String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─────────────────────────────────────────────
  // LANGUAGE
  // ─────────────────────────────────────────────

  model Translation {
    id            String   @id @default(cuid())
    locale        String   // "en", "hi", "es"
    key           String
    value         String   @db.Text
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@unique([locale, key])
    @@index([locale])
    @@map("translations")
  }

  // ─────────────────────────────────────────────
  // BANNER MANAGEMENT
  // ─────────────────────────────────────────────

  model Banner {
    id            String   @id @default(cuid())
    title         String
    subtitle      String?
    image         String
    link          String?
    linkType      String?  // "product", "category", "url"
    position      String   @default("home") // "home", "category", "product"
    isActive      Boolean  @default(true)
    sortOrder     Int      @default(0)
    startsAt      DateTime?
    expiresAt     DateTime?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@index([position, isActive])
    @@map("banners")
  }

  // ─────────────────────────────────────────────
  // RETURN/REFUND MANAGEMENT
  // ─────────────────────────────────────────────

  enum ReturnStatus {
    PENDING
    APPROVED
    REJECTED
    RECEIVED
    PROCESSED
    COMPLETED
  }

  enum RefundMethod {
    ORIGINAL
    STORE_CREDIT
  }

  model ReturnRequest {
    id              String        @id @default(cuid())
    returnNumber    String        @unique
    reason          String        @db.Text
    status          ReturnStatus  @default(PENDING)
    refundMethod    RefundMethod  @default(ORIGINAL)
    refundAmount    Decimal?      @db.Decimal(10, 2)
    rejectionReason String?
    images          String[]
    adminNotes      String?       @db.Text
    createdAt       DateTime      @default(now())
    updatedAt       DateTime      @updatedAt
    processedAt     DateTime?

    orderId         String
    order           Order         @relation(fields: [orderId], references: [id])

    items           ReturnItem[]

    @@index([status])
    @@index([orderId])
    @@map("return_requests")
  }

  model ReturnItem {
    id            String   @id @default(cuid())

    returnId      String
    returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)

    orderItemId   String
    quantity      Int      @default(1)

    @@index([returnId])
    @@map("return_items")
  }

  // ─────────────────────────────────────────────
  // SHIPPING ZONES & RATES
  // ─────────────────────────────────────────────

  model ShippingZone {
    id          String   @id @default(cuid())
    name        String
    countries   String[] // Country codes
    regions     String[] // State/region codes
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    rates       ShippingRate[]

    @@map("shipping_zones")
  }

  model ShippingRate {
    id              String   @id @default(cuid())
    name            String
    description     String?
    price           Decimal  @db.Decimal(10, 2)
    freeShippingThreshold Decimal? @db.Decimal(10, 2)
    minWeight       Decimal? @db.Decimal(10, 2) // in kg
    maxWeight       Decimal? @db.Decimal(10, 2) // in kg
    estimatedDays   String?  // "3-5 days"
    isActive        Boolean  @default(true)
    sortOrder       Int      @default(0)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    zoneId          String
    zone            ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

    @@index([zoneId])
    @@map("shipping_rates")
  }

  // ─────────────────────────────────────────────
  // FLASH SALES
  // ─────────────────────────────────────────────

  model FlashSale {
    id          String   @id @default(cuid())
    name        String
    description String?
    discount    Decimal  @db.Decimal(10, 2) // Percentage
    isActive    Boolean  @default(true)
    startsAt    DateTime
    endsAt      DateTime
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    products    FlashSaleProduct[]

    @@index([isActive, startsAt, endsAt])
    @@map("flash_sales")
  }

  model FlashSaleProduct {
    id          String   @id @default(cuid())
    flashSaleId String
    flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)

    productId   String
    product     Product   @relation(fields: [productId], references: [id])

    variantId   String?

    @@unique([flashSaleId, productId, variantId])
    @@map("flash_sale_products")
  }

  // ─────────────────────────────────────────────
  // PRODUCT BUNDLES
  // ─────────────────────────────────────────────

  model ProductBundle {
    id          String   @id @default(cuid())
    name        String
    description String?
    image       String?
    bundlePrice Decimal  @db.Decimal(10, 2)
    discount    Decimal  @db.Decimal(10, 2) // Percentage off
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    products    BundleProduct[]

    @@index([isActive])
    @@map("product_bundles")
  }

  model BundleProduct {
    id          String   @id @default(cuid())

    bundleId    String
    bundle      ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

    productId   String
    product     Product   @relation(fields: [productId], references: [id])

    quantity    Int      @default(1)

    @@index([bundleId])
    @@map("bundle_products")
  }

  // ─────────────────────────────────────────────
  // SITE SETTINGS
  // ─────────────────────────────────────────────

  model SiteSetting {
    id        String   @id @default(cuid())
    key       String   @unique
    value     Json
    category  String   @default("general") // "general", "payment", "shipping", "seo", "social"
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("site_settings")
  }

  // ─────────────────────────────────────────────
  // AUDIT LOGS
  // ─────────────────────────────────────────────

  enum AuditAction {
    CREATE
    UPDATE
    DELETE
    LOGIN
    LOGOUT
    EXPORT
    APPROVE
    REJECT
  }

  model AuditLog {
    id          String      @id @default(cuid())
    action      AuditAction
    entityType  String      // "product", "order", "user", etc.
    entityId    String?
    oldValue    Json?
    newValue    Json?
    ipAddress   String?
    userAgent   String?
    createdAt   DateTime    @default(now())

    userId      String?
    user        User?       @relation(fields: [userId], references: [id])

    @@index([userId, action])
    @@index([entityType, entityId])
    @@index([createdAt])
    @@map("audit_logs")
  }

  // ─────────────────────────────────────────────
  // BLOG / CMS
  // ─────────────────────────────────────────────

  model BlogPost {
    id          String   @id @default(cuid())
    title       String
    slug        String   @unique
    content     String   @db.Text
    excerpt     String?
    image       String?
    author      String?
    isPublished Boolean  @default(false)
    isFeatured  Boolean  @default(false)
    tags        String[]
    metaTitle   String?
    metaDescription String?
    sortOrder   Int      @default(0)
    publishedAt DateTime?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([slug])
    @@index([isPublished])
    @@map("blog_posts")
  }

  // ─────────────────────────────────────────────
  // ADMIN ROLES & PERMISSIONS
  // ─────────────────────────────────────────────

  model AdminRole {
    id          String   @id @default(cuid())
    name        String   @unique
    description String?
    permissions String[] // "products.manage", "orders.view", etc.
    isDefault   Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    admins      AdminUser[]

    @@map("admin_roles")
  }

  model AdminUser {
    id          String   @id @default(cuid())
    userId      String   @unique
    user        User     @relation(fields: [userId], references: [id])

    roleId      String
    role        AdminRole @relation(fields: [roleId], references: [id])

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([roleId])
    @@map("admin_users")
  }

  // ─────────────────────────────────────────────
  // PUSH NOTIFICATIONS
  // ─────────────────────────────────────────────

  model PushSubscription {
    id        String   @id @default(cuid())
    userId    String
    endpoint  String   @unique
    p256dh    String
    auth      String
    createdAt DateTime @default(now())

    @@index([userId])
    @@map("push_subscriptions")
  }

  // ─────────────────────────────────────────────
  // LOYALTY REWARDS
  // ─────────────────────────────────────────────

  model LoyaltyPoints {
    id          String   @id @default(cuid())
    userId      String   @unique
    points      Int      @default(0)
    lifetime    Int      @default(0)
    updatedAt   DateTime @updatedAt
    createdAt   DateTime @default(now())

    user        User     @relation(fields: [userId], references: [id])

    @@index([userId])
    @@map("loyalty_points")
  }

  model LoyaltyTransaction {
    id          String   @id @default(cuid())
    type        String   // "earn", "redeem", "expire", "adjust"
    points      Int
    balance     Int
    description String?
    orderId     String?
    expiresAt   DateTime?
    createdAt   DateTime @default(now())

    userId      String
    user        User     @relation(fields: [userId], references: [id])

    @@index([userId])
    @@index([orderId])
    @@map("loyalty_transactions")
  }

  model LoyaltyTier {
    id          String   @id @default(cuid())
    name        String   @unique // "Bronze", "Silver", "Gold", "Platinum"
    minPoints   Int
    discount    Decimal  @db.Decimal(5, 2) // Percentage discount
    perks       String[] // ["free_shipping", "early_access"]
    createdAt   DateTime @default(now())

    @@map("loyalty_tiers")
  }

  // ─────────────────────────────────────────────
  // PRODUCT VIEWS (for recommendations)
  // ─────────────────────────────────────────────

  model ProductView {
    id          String   @id @default(cuid())
    userId      String?
    sessionId   String?
    productId   String
    source      String?  // "search", "category", "recommendation", "direct"
    createdAt   DateTime @default(now())

    product     Product  @relation(fields: [productId], references: [id])

